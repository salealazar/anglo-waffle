# Copia este archivo a `.env` y completa los valores.
#   cp .env.example .env

# ── Comunes a ambas variantes de deploy ───────────────────────────────────

# Auth básica del curso (formato usuario:clave). Es lo que pides una vez en el
# navegador para entrar al laboratorio. Repártela a los alumnos.
LAB_BASIC_AUTH=curso:CambiaEstaClave

# Clave del SUPERUSUARIO de Postgres. Aunque el puerto no se publica, ponla
# fuerte por defensa en profundidad. Genera una con: openssl rand -base64 24
POSTGRES_PASSWORD=pon-aqui-una-clave-larga-y-aleatoria

# ── Solo para docker-compose.path.yml (path en el host de faro) ────────────

# Sub-ruta donde se sirve el lab. Debe coincidir con el "location" del nginx
# (nginx/sqli-lab.conf). Por defecto /sqli-lab.
BASE_PATH=/sqli-lab

# ── Solo para docker-compose.deploy.yml (subdominio propio con Caddy) ──────

# Dominio público que apunta (DNS) a este host. Caddy emite el TLS para él.
LAB_DOMAIN=sqli-lab.example.cl
